<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Book Library</title>
    <link rel="stylesheet" href="/main.css">
    <link rel="stylesheet" href="/author.css">
</head>
<body>            text-decoration: none;
            border-radius: 5px;
        }

</head>
<body>
    <%- include('partials/header-nav') %>

    <a href="/" class="back-link">← Back to All Books</a>
    <h2><%= title %></h2>
    <div class="book-list">
        <% books.forEach(book => { %>
        <div class="book-card">
            <h3><%= book.title %></h3>
            <p><strong>Author:</strong> <%= book.author %></p>
            <p><strong>Genre:</strong> <a href="/books/genre/<%= encodeURIComponent(book.genre) %>"><%= book.genre %></a></p>
            <p><strong>Year:</strong> <a href="/books/year/<%= book.year %>"><%= book.year %></a></p>
            <div class="book-links">
                <a href="/books/title/<%= encodeURIComponent(book.title) %>">View Details</a>
            </div>
        </div>
        <% }); %>
    </div>
</body>
</html>