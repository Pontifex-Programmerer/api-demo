<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Book Library</title>
    <link rel="stylesheet" href="/main.css">
    <link rel="stylesheet" href="/book.css">

</head>
<body>
    <%- include('partials/header-nav') %>

    <div class="book-detail">
        <h2><%= book.title %></h2>
        <p><strong>Author:</strong> <a href="/books/author/<%= encodeURIComponent(book.author) %>"><%= book.author %></a></p>
        <p><strong>Genre:</strong> <a href="/books/genre/<%= encodeURIComponent(book.genre) %>"><%= book.genre %></a></p>
        <p><strong>Year:</strong> <a href="/books/year/<%= book.year %>"><%= book.year %></a></p>
        <a href="/" class="back-link">← Back to All Books</a>
    </div>
</body>
</html>